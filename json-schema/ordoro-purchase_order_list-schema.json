{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-purchase_order_list-schema.json",
  "title": "Purchase Order List Response schema",
  "type": "object",
  "properties": {
    "limit": {
      "type": "integer",
      "example": 1
    },
    "offset": {
      "type": "integer",
      "example": 0
    },
    "count": {
      "type": "integer",
      "example": 46
    },
    "purchase_order": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/purchase_order"
      }
    }
  }
}