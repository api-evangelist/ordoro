{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-company_logo-schema.json",
  "title": "Company Logo Response Schema",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "_link": {
      "type": "string"
    },
    "company_id": {
      "type": "integer"
    },
    "data": {
      "type": "string",
      "example": ""
    },
    "name": {
      "type": "string"
    },
    "mime_type": {
      "type": "string",
      "example": "image/png"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    }
  }
}