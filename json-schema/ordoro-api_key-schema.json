{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-api_key-schema.json",
  "title": "API Key Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "client_secret": {
      "type": "string"
    },
    "archive_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "created": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "company_id": {
      "type": "integer"
    },
    "user_id": {
      "type": "integer"
    }
  },
  "required": [
    "id",
    "name",
    "client_id",
    "client_secret",
    "archive_date",
    "created",
    "updated",
    "company_id",
    "user_id"
  ]
}