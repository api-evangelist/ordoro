{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-post_return_order-schema.json",
  "title": "Create a Return Order",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reference_id": {
      "type": "string"
    },
    "original_order_number": {
      "type": "string"
    },
    "warehouse_id": {
      "type": "integer"
    },
    "customer_address": {
      "$ref": "#/components/schemas/v1_address"
    },
    "return_to_address": {
      "$ref": "#/components/schemas/v1_address"
    },
    "customer_notes": {
      "type": "string"
    },
    "internal_notes": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "expected_quantity": {
            "type": "number"
          }
        }
      }
    }
  },
  "required": [
    "reference_id",
    "customer_address",
    "lines"
  ]
}