{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-user-schema.json",
  "title": "User Schema",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "_link": {
      "type": "string"
    },
    "id": {
      "type": "integer"
    },
    "company_id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean"
    },
    "is_api_user": {
      "type": "boolean"
    },
    "last_login": {
      "type": "string",
      "format": "date-time"
    },
    "date_joined": {
      "format": "date-time",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "email_verified": {
      "format": "date-time",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "permissions": {
      "type": "object"
    },
    "settings": {
      "type": "object"
    }
  },
  "required": [
    "id",
    "company_id",
    "name",
    "email",
    "is_active",
    "is_api_user",
    "last_login",
    "date_joined",
    "permissions",
    "settings"
  ]
}