{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ordoro/refs/heads/main/json-schema/ordoro-post_purchase_order-schema.json",
  "title": "Buy More Products Request Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "supplier_id": {
      "type": "integer"
    },
    "warehouse_id": {
      "type": "integer"
    },
    "po_id": {
      "type": "string"
    },
    "shipping_method": {
      "type": "string"
    },
    "payment_method": {
      "type": "string"
    },
    "instructions": {
      "type": "string"
    },
    "estimated_delivery_date": {
      "type": "string"
    },
    "shipping_amount": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    },
    "discount_amount": {
      "type": "number"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "#/components/schemas/purchase_order_item"
      }
    }
  },
  "required": [
    "supplier_id"
  ]
}